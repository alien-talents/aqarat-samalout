# Supabase Configuration
# Copy this file to .env and fill in your actual values

# Supabase Project URL - Used for Supabase client connection
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Publishable/Anon Key (Client-side) - Safe to expose in browser
VITE_SUPABASE_ANON_KEY=sb_publishable_your_key_here

# Direct Database Connection (Server-side only - DO NOT expose to browser)
# Replace [YOUR-PASSWORD] with your actual database password
SUPABASE_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-id.supabase.co:5432/postgres
